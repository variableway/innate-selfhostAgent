{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Innate Playground",
  "version": "0.1.0",
  "identifier": "com.innate.playground",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "node ./node_modules/next/dist/bin/next dev --port 3001",
    "beforeBuildCommand": "node ./node_modules/next/dist/bin/next build"
  },
  "app": {
    "windows": [
      {
        "title": "Innate Playground - 边做边学",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": "^"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
